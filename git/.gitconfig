[user]
	email = simon@simonwg.com
	name = Simon Westlin Green
	signingKey = 346607848E27D01B
[includeIf "gitdir:~/Programming/work/**"]
	path = ~/Programming/work/.gitconfig
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[commit]
	gpgSign = true
[tag]
	gpgSign = true
[sendemail]
	smtpServer = 127.0.0.1
	smtpServerPort = 1025
	smtpEncryption = tls
	smtpUser = simon@simonwg.com
	smtpSSLCertPath =
[credential]
	helper = libsecret
