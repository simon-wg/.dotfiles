{
    "layer": "top",
    "height": 26,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["battery", "tray"],
    "sway/window": {
        "max-length": 50
    },
    "battery": {
        "format": "{capacity}%",
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    }
}
